# CLI Runner image for Claude Code CLI execution
# Based on Ubuntu for better compatibility with Claude Code CLI

FROM ubuntu:22.04

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    gnupg \
    ca-certificates \
    build-essential \
    python3 \
    python3-pip \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code CLI
# Note: The actual installation method depends on Anthropic's distribution
# This is a placeholder - update with actual Claude Code CLI installation
RUN curl -fsSL https://claude.ai/cli/install.sh | bash || \
    echo "Claude Code CLI installation placeholder"

# Create workspace directory
RUN mkdir -p /workspace && chmod 755 /workspace

# Create non-root user (will be overridden at runtime for specific task)
RUN useradd -m -u 1000 -s /bin/bash runner

# Copy CLI runner scripts
COPY scripts/cli-runner.sh /scripts/cli-runner.sh
RUN chmod +x /scripts/cli-runner.sh

# Set working directory
WORKDIR /workspace

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD pgrep -f "claude" > /dev/null || exit 1

# Entry point
ENTRYPOINT ["/scripts/cli-runner.sh"]
